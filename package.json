{
  "name": "theleadgen-io",
  "private": true,
  "scripts": {
    "build:css": "bunx @tailwindcss/cli -i ./styles.css -o ./dist.css --minify",
    "dev": "bun run build:css && bun --hot server.ts",
    "build": "bun run build:css && bun build ./index.html --outdir ./dist --minify && cp ./dist.css ./dist/dist.css",
    "vercel-build": "bun run build"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
